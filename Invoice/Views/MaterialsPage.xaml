<Page
    x:Class="Invoice.Views.MaterialsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"        
    mc:Ignorable="d">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="DataGridBorderColor" Color="Black"/>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="DataGridBorderColor" Color="Gray"/>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

            <Style x:Key="CustomHeaderStyle" TargetType="ContentControl">
                <Setter Property="FontSize" Value="15"/>
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="HorizontalContentAlignment" Value="Center"/>
            </Style>
        </ResourceDictionary>
    </Page.Resources>
    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                  HorizontalScrollMode="Auto" VerticalScrollMode="Auto" ZoomMode="Disabled">
        <Grid x:Name="ContentArea">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                <StackPanel Orientation="Vertical" Margin="0,0,0,10">
                    <StackPanel Orientation="Vertical" Spacing="10">
                        <StackPanel>
                            <TextBlock>
                                <Run x:Uid="CreateInvoice_CustomerName_Required" Foreground="Red"/>
                                <Run x:Uid="Products_Name"/>
                            </TextBlock>
                            <TextBox x:Name="txtName" Width="300" HorizontalAlignment="Left"/>
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Left">
                            <TextBlock>                                
                                <Run x:Uid="CreateInvoice_CustomerName_Required" Foreground="Red"/>
                                <Run x:Uid="Materials_Price"/>
                            </TextBlock>
                            <TextBox x:Name="txtBasePrice" Width="140" TextAlignment="Right"
                                     BeforeTextChanging="Number_BeforeTextChanging"/>
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Left">
                            <TextBlock x:Uid="Materials_Total"/>
                            <TextBox x:Name="txtTotal" Width="140" TextAlignment="Right"/>
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Left">
                            <TextBlock x:Uid="Materials_MinInventory"/>
                            <TextBox x:Name="txtMinAmount"
                                     BeforeTextChanging="Number_BeforeTextChanging"
                                     Width="140" TextAlignment="Right"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
                <Grid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <CommandBar Background="Transparent" DefaultLabelPosition="Right" >
                            <AppBarButton x:Name="btnAdd" x:Uid="Btn_add" Background="#07af00" Foreground="{ThemeResource SettingsForegroundBrush}"
                                          CornerRadius="10" Icon="Add" Click="BtnNew_Click"/>
                            <AppBarButton x:Name="btnDelete" x:Uid="Btn_Delete" Background="#ff3800" Foreground="{ThemeResource SettingsForegroundBrush}"
                                          CornerRadius="10" Icon="Delete" Click="BtnDelete_Click"/>
                            <AppBarButton x:Name="btnUpdate" x:Uid="Btn_Update" Background="#b48b14" Foreground="{ThemeResource SettingsForegroundBrush}"
                                          CornerRadius="10" Icon="Edit" Click="BtnUpdate_Click"/>
                            <AppBarButton x:Name="btnReset" x:Uid="Btn_Reset" Background="#24a6d5" Foreground="{ThemeResource SettingsForegroundBrush}"
                                          CornerRadius="10" Icon="Refresh" Click="BtnReset_Click"/>
                        </CommandBar>
                    </StackPanel>
                </Grid>
            </StackPanel>
            <StackPanel
                Grid.Column="1"
                Orientation="Vertical">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock x:Uid="Customers_Search" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox x:Name="txtSearch" x:Uid="Materials_Search_Placeholder" Width="250" TextChanged="txtSearch_TextChanged" />
                </StackPanel>

                <controls:DataGrid
                    x:Name="MaterialGrid"                
                    MaxHeight="600"
                    VerticalAlignment="Top"
                    AutoGenerateColumns="False"            
                    GridLinesVisibility="All"            
                    IsReadOnly="True"
                    SelectionMode="Single"
                    CanUserReorderColumns="False"
                    CanUserSortColumns="False"            
                    CanUserResizeColumns="False"
                    ScrollViewer.VerticalScrollBarVisibility="Auto"
                    ColumnHeaderStyle="{StaticResource CustomHeaderStyle}"
                    HorizontalGridLinesBrush="{ThemeResource DataGridBorderColor}"
                    VerticalGridLinesBrush="{ThemeResource DataGridBorderColor}"  
                    BorderThickness="1"
                    ItemsSource="{x:Bind ViewModel.MaterialsCollection, Mode=OneWay}"
                    SelectionChanged="MaterialGrid_SelectionChanged">

                    <controls:DataGrid.Resources>
                        <SolidColorBrush x:Key="DataGridColumnHeaderBackgroundColor" Color="Transparent" />
                    </controls:DataGrid.Resources>
                    <controls:DataGrid.Columns>
                        <controls:DataGridTextColumn Binding="{Binding ProductID}" x:Uid="Materials_Grid_ProductID" Visibility="Collapsed"/>
                        <controls:DataGridTextColumn Width="200" Binding="{Binding Name}" x:Uid="Materials_Grid_Name" />
                        <controls:DataGridTextColumn Binding="{Binding BasePrice}" x:Uid="Materials_Grid_Price">
                            <controls:DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Stretch"/>
                                    <Setter Property="TextAlignment" Value="Right"/>
                                </Style>
                            </controls:DataGridTextColumn.ElementStyle>
                        </controls:DataGridTextColumn>
                        <controls:DataGridTextColumn Binding="{Binding Inventory}" x:Uid="Materials_Grid_Inventory">
                            <controls:DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Stretch"/>
                                    <Setter Property="TextAlignment" Value="Right"/>
                                </Style>
                            </controls:DataGridTextColumn.ElementStyle>
                        </controls:DataGridTextColumn>
                        <controls:DataGridTextColumn Binding="{Binding TotalLine}" x:Uid="Materials_Grid_Total">
                            <controls:DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Stretch"/>
                                    <Setter Property="TextAlignment" Value="Right"/>
                                </Style>
                            </controls:DataGridTextColumn.ElementStyle>
                        </controls:DataGridTextColumn>
                        <controls:DataGridTextColumn Binding="{Binding MinAmount}" x:Uid="Materials_Grid_MinInventory">
                            <controls:DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Stretch"/>
                                    <Setter Property="TextAlignment" Value="Right"/>
                                </Style>
                            </controls:DataGridTextColumn.ElementStyle>
                        </controls:DataGridTextColumn>
                    </controls:DataGrid.Columns>
                </controls:DataGrid>
            </StackPanel>

            <ProgressRing Grid.Column="1"
                  IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}"
                  Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"
                  Width="60" Height="60"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center" />
        </Grid>
    </ScrollViewer>
</Page>
