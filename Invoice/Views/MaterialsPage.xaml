<Page
    x:Class="Invoice.Views.MaterialsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:behaviors="using:Invoice.Behaviors"
    xmlns:converters="using:Invoice.Helpers"
    mc:Ignorable="d">
    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="DataGridBorderColor" Color="Black"/>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="DataGridBorderColor" Color="Gray"/>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

            <Style x:Key="CustomHeaderStyle" TargetType="ContentControl">
                <Setter Property="FontSize" Value="15"/>
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="HorizontalContentAlignment" Value="Center"/>
            </Style>

            <converters:InventoryToColorConverter x:Key="InventoryColorConverter"/>
        </ResourceDictionary>
    </Page.Resources>
    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                  HorizontalScrollMode="Auto" VerticalScrollMode="Auto" ZoomMode="Disabled">
        <Grid x:Name="ContentArea">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                <StackPanel Orientation="Vertical" Margin="0,0,0,10">
                    <StackPanel Orientation="Vertical" Spacing="10">
                        <StackPanel>
                            <TextBlock>                                
                                <Run Text="Tên vật tư"/>
                            </TextBlock>
                            <TextBox x:Name="txtName" Width="300" HorizontalAlignment="Left"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="20">
                            <StackPanel Orientation="Vertical" Spacing="10">
                                 <StackPanel HorizontalAlignment="Left">
                                    <TextBlock>                                                                
                                        <Run Text="Giá"/>
                                    </TextBlock>
                                    <TextBox x:Name="txtBasePrice" Width="140" TextAlignment="Right"
                                             behaviors:TextBoxInputBehavior.InputType="Decimal" />
                                </StackPanel>
                                <StackPanel HorizontalAlignment="Left">
                                    <TextBlock>                                
                                    <Run Text="Tổng tiền :"/>
                                    </TextBlock>
                                    <TextBox x:Name="txtTotal" Width="140" TextAlignment="Right"/>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Orientation="Vertical" Spacing="10">
                                <StackPanel HorizontalAlignment="Left">
                                    <TextBlock>                                
                                        <Run Text="Tồn kho tối thiểu"/>
                                    </TextBlock>
                                    <TextBox x:Name="txtMinAmount"
                                             behaviors:TextBoxInputBehavior.InputType="Numeric"
                                             Width="140" TextAlignment="Right"/>
                                </StackPanel>
                                <StackPanel HorizontalAlignment="Left">
                                    <TextBlock>                                
                                        <Run Text="Đơn vị"/>
                                    </TextBlock>
                                    <TextBox x:Name="txtUnit"
                                         Width="140" TextAlignment="Right"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                        
                        
                    </StackPanel>
                </StackPanel>
                <Grid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <CommandBar Background="Transparent" DefaultLabelPosition="Right" >
                            <AppBarButton x:Name="btnAdd" Label="Thêm" Background="#07af00" Foreground="{ThemeResource SettingsForegroundBrush}"
                                          CornerRadius="10" Icon="Add" Click="BtnNew_Click"/>
                            <AppBarButton x:Name="btnDelete" Label="Xóa" Background="#ff3800" Foreground="{ThemeResource SettingsForegroundBrush}"
                                          CornerRadius="10" Icon="Delete" Click="BtnDelete_Click"/>
                            <AppBarButton x:Name="btnUpdate" Label="Cập nhật" Background="#b48b14" Foreground="{ThemeResource SettingsForegroundBrush}"
                                          CornerRadius="10" Icon="Edit" Click="BtnUpdate_Click"/>
                            <AppBarButton x:Name="btnReset" Label="Đặt lại" Background="#24a6d5" Foreground="{ThemeResource SettingsForegroundBrush}"
                                          CornerRadius="10" Icon="Refresh" Click="BtnReset_Click"/>
                        </CommandBar>
                    </StackPanel>
                </Grid>
            </StackPanel>
            <StackPanel
                Grid.Column="1"
                Orientation="Vertical">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="Tìm kiếm" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox x:Name="txtSearch" Width="250" TextChanged="txtSearch_TextChanged" />
                </StackPanel>

                <controls:DataGrid
                    x:Name="MaterialGrid"                
                    MaxHeight="600"
                    VerticalAlignment="Top"
                    AutoGenerateColumns="False"            
                    GridLinesVisibility="All"            
                    IsReadOnly="True"
                    SelectionMode="Single"
                    CanUserReorderColumns="False"
                    CanUserSortColumns="False"            
                    CanUserResizeColumns="False"
                    ScrollViewer.VerticalScrollBarVisibility="Auto"
                    ColumnHeaderStyle="{StaticResource CustomHeaderStyle}"
                    HorizontalGridLinesBrush="{ThemeResource DataGridBorderColor}"
                    VerticalGridLinesBrush="{ThemeResource DataGridBorderColor}"  
                    BorderThickness="1"
                    ItemsSource="{x:Bind ViewModel.MaterialsCollection, Mode=OneWay}"
                    SelectionChanged="MaterialGrid_SelectionChanged">

                    <controls:DataGrid.Resources>
                        <SolidColorBrush x:Key="DataGridColumnHeaderBackgroundColor" Color="Transparent" />
                    </controls:DataGrid.Resources>
                    <controls:DataGrid.Columns>
                        <controls:DataGridTextColumn Width="200" Binding="{Binding Name}" Header="Tên hàng" />
                        <controls:DataGridTextColumn Binding="{Binding BasePrice}" Header="Đơn giá">
                            <controls:DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Stretch"/>
                                    <Setter Property="TextAlignment" Value="Right"/>
                                </Style>
                            </controls:DataGridTextColumn.ElementStyle>
                        </controls:DataGridTextColumn>
                        <controls:DataGridTemplateColumn Header="Tồn kho">
                            <controls:DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="{Binding Converter={StaticResource InventoryColorConverter}}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                        <TextBlock Text="{Binding Inventory}" 
                                                   TextAlignment="Right" 
                                                   VerticalAlignment="Center" 
                                                   Padding="10,0"
                                                   HorizontalAlignment="Stretch"/>
                                    </Border>
                                </DataTemplate>
                            </controls:DataGridTemplateColumn.CellTemplate>
                        </controls:DataGridTemplateColumn>
                        <controls:DataGridTextColumn Binding="{Binding TotalLine}" Header="Thành tiền">
                            <controls:DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Stretch"/>
                                    <Setter Property="TextAlignment" Value="Right"/>
                                </Style>
                            </controls:DataGridTextColumn.ElementStyle>
                        </controls:DataGridTextColumn>
                        <controls:DataGridTextColumn Binding="{Binding Unit}" Header="Đơn vị">
                            <controls:DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Stretch"/>
                                    <Setter Property="TextAlignment" Value="Right"/>
                                </Style>
                            </controls:DataGridTextColumn.ElementStyle>
                        </controls:DataGridTextColumn>
                        <controls:DataGridTextColumn Binding="{Binding MinAmount}" Header="Tồn kho tối thiểu">
                            <controls:DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Stretch"/>
                                    <Setter Property="TextAlignment" Value="Right"/>
                                </Style>
                            </controls:DataGridTextColumn.ElementStyle>
                        </controls:DataGridTextColumn>
                    </controls:DataGrid.Columns>
                </controls:DataGrid>
            </StackPanel>

            <ProgressRing Grid.Column="1"
                  IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}"
                  Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"
                  Width="60" Height="60"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center" />
        </Grid>
    </ScrollViewer>
</Page>
