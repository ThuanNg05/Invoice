<Page
    x:Class="Invoice.Views.EditingInvoicePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:converters="using:Invoice.Helpers"
    Background="#272727"
    mc:Ignorable="d">

    <Page.Resources>
        <!-- Style áp dụng cho header của DataGrid -->
        <Style x:Key="CustomHeaderStyle" TargetType="ContentControl">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}"/>
        </Style>
        <converters:DoubleToStringConverter x:Key="FormatConverter"/>
        <converters:DateTimeFormatter x:Key="DateFormat"/>
    </Page.Resources>

    <Grid x:Name="ContentArea" Padding="50">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="16" Margin="0,0,0,16" VerticalAlignment="Bottom">

            <StackPanel Spacing="4">
                <TextBlock Text="Mã HĐ" Style="{ThemeResource CaptionTextBlockStyle}" FontSize="15" FontStyle="Italic" FontWeight="Bold"/>
                <ComboBox ItemsSource="{x:Bind ViewModel.InvoiceCodes, Mode=OneWay}" 
                          SelectedItem="{x:Bind ViewModel.SelectedInvoiceID, Mode=TwoWay}"
                          x:Name="invoiceCode"
                          Text="Chọn hoá đơn"
                          Width="180"/>
            </StackPanel>

            <StackPanel>
                <TextBlock Margin="0,0,0,3">                    
                    <Run Text="Khách hàng" FontSize="15" FontStyle="Italic" FontWeight="Bold"/>
                </TextBlock>
                <TextBox Text="{x:Bind ViewModel.CustomerName, Mode=OneWay}"
                    x:Name="customer" IsReadOnly="True" IsSpellCheckEnabled="False" Width="Auto"/>
            </StackPanel>

            <StackPanel>
                <TextBlock Margin="0,0,0,3">                    
                    <Run Text="Ngày tạo" FontSize="15" FontStyle="Italic" FontWeight="Bold" />
                </TextBlock>
                <TextBox Text="{x:Bind ViewModel.CreatedDate, Mode=OneWay}"
                    x:Name="createdDate" IsReadOnly="True" IsSpellCheckEnabled="False" Width="Auto"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Spacing="10" Margin="0,10,0,0">
                <CommandBar Background="Transparent" DefaultLabelPosition="Right">
                    <AppBarButton Background="#b48b14" Label="Load" Command="{x:Bind ViewModel.ConfirmLoadCommand}" ToolTipService.ToolTip="Press F1" CornerRadius="10">
                        <AppBarButton.Icon>
                            <FontIcon Glyph="&#xE8B6;"/>
                        </AppBarButton.Icon>
                        <AppBarButton.KeyboardAccelerators>
                            <KeyboardAccelerator Key="F1"/>
                        </AppBarButton.KeyboardAccelerators>
                    </AppBarButton>
                    <AppBarButton Label="Đặt lại" Background="#24a6d5" Icon="Refresh" Command="{x:Bind ViewModel.ResetCommand}" ToolTipService.ToolTip="Press F2" CornerRadius="10">
                        <AppBarButton.KeyboardAccelerators>
                            <KeyboardAccelerator Key="F2"/>
                        </AppBarButton.KeyboardAccelerators>
                    </AppBarButton>
                </CommandBar>
            </StackPanel>
        </StackPanel>

        <controls:DataGrid Grid.Row="1"
                           x:Name="DetailInvoice"
                           MaxHeight="600"
                           VerticalAlignment="Top"                           
                           GridLinesVisibility="All"
                           CanUserReorderColumns="False"
                           CanUserSortColumns="False"
                           AutoGenerateColumns="False"                           
                           IsReadOnly="True"
                           ScrollViewer.VerticalScrollBarVisibility="Auto"
                           ColumnHeaderStyle="{StaticResource CustomHeaderStyle}"
                           ItemsSource="{x:Bind ViewModel.InvoiceDetails, Mode=OneWay}"
                           SelectionMode="Single">

            <controls:DataGrid.Resources>
                <SolidColorBrush x:Key="DataGridColumnHeaderBackgroundColor" Color="Transparent" />
            </controls:DataGrid.Resources>

            <controls:DataGrid.Columns>
                <!--<controls:DataGridTextColumn Header="Mã SP" Binding="{Binding ProductID}" Visibility="Collapsed">
                    <controls:DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Stretch"/>
                            <Setter Property="TextAlignment" Value="Left"/>
                        </Style>
                    </controls:DataGridTextColumn.ElementStyle>
                </controls:DataGridTextColumn>-->

                <controls:DataGridTextColumn Header="Tên SP" Binding="{Binding ProductName}">
                    <controls:DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Stretch"/>
                            <Setter Property="TextAlignment" Value="Left"/>
                        </Style>
                    </controls:DataGridTextColumn.ElementStyle>
                </controls:DataGridTextColumn>

                <controls:DataGridTextColumn Header="Đơn giá" Binding="{Binding SellPrice, Converter={StaticResource FormatConverter}, ConverterParameter='N0'}">
                    <controls:DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Stretch"/>
                            <Setter Property="TextAlignment" Value="Right"/>
                        </Style>
                    </controls:DataGridTextColumn.ElementStyle>
                </controls:DataGridTextColumn>

                <controls:DataGridTextColumn Header="Số lượng" Binding="{Binding Amount}">
                    <controls:DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Stretch"/>
                            <Setter Property="TextAlignment" Value="Center"/>
                        </Style>
                    </controls:DataGridTextColumn.ElementStyle>
                </controls:DataGridTextColumn>

                <controls:DataGridTextColumn Header="Thành tiền" Binding="{Binding LineTotal, Converter={StaticResource FormatConverter}, ConverterParameter='N0'}">
                    <controls:DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Stretch"/>
                            <Setter Property="TextAlignment" Value="Right"/>
                        </Style>
                    </controls:DataGridTextColumn.ElementStyle>
                </controls:DataGridTextColumn>

                <controls:DataGridTextColumn Header="Ghi chú" Binding="{Binding Note}">
                    <controls:DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Stretch"/>
                            <Setter Property="TextAlignment" Value="Left"/>
                        </Style>
                    </controls:DataGridTextColumn.ElementStyle>
                </controls:DataGridTextColumn>
            </controls:DataGrid.Columns>
        </controls:DataGrid>
    </Grid>
</Page>
