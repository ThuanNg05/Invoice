<Page
    x:Class="Invoice.Views.IOPlanksPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    mc:Ignorable="d">

	<Page.Resources>
		<ResourceDictionary>
			<ResourceDictionary.ThemeDictionaries>
				<ResourceDictionary x:Key="Light">
					<SolidColorBrush x:Key="DataGridBorderColor" Color="Black"/>
				</ResourceDictionary>
				<ResourceDictionary x:Key="Dark">
					<SolidColorBrush x:Key="DataGridBorderColor" Color="Gray"/>
				</ResourceDictionary>
			</ResourceDictionary.ThemeDictionaries>

			<Style x:Key="CustomHeaderStyle" TargetType="ContentControl">
				<Setter Property="FontSize" Value="15"/>
				<Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}"/>
				<Setter Property="FontWeight" Value="Bold"/>
				<Setter Property="HorizontalContentAlignment" Value="Center"/>
			</Style>
		</ResourceDictionary>
	</Page.Resources>

	<Grid x:Name="ContentArea" Padding="20">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>

		<StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="16" Margin="0,0,0,16" VerticalAlignment="Bottom">

			<StackPanel Orientation="Vertical" Spacing="10">
				<StackPanel Orientation="Horizontal" Spacing="10">
					<TextBox x:Name="size1" Header="Kích thước" TextAlignment="Left" IsReadOnly="true"/>
					<TextBox x:Name="size2" Header=" " TextAlignment="Left" IsReadOnly="true"/>
					<TextBox x:Name="size3" Header=" " TextAlignment="Left" IsReadOnly="true"/>
					<TextBox x:Name="size4" Header=" " TextAlignment="Left" IsReadOnly="true"/>
					<TextBox x:Name="size5" Header=" " TextAlignment="Left" IsReadOnly="true"/>
					<TextBox x:Name="size6" Header=" " TextAlignment="Left" IsReadOnly="true"/>
					<TextBox x:Name="size7" Header=" " TextAlignment="Left" IsReadOnly="true"/>
					<TextBox x:Name="size8" Header=" " TextAlignment="Left" IsReadOnly="true"/>
					<TextBox x:Name="size9" Header=" " TextAlignment="Left" IsReadOnly="true"/>
					<TextBox x:Name="size10" Header=" " TextAlignment="Left" IsReadOnly="true"/>
				</StackPanel>

				<StackPanel Orientation="Horizontal" Spacing="10">
					<TextBox x:Name="amount1" Header="Số lượng" TextAlignment="Right" IsReadOnly="true"/>
					<TextBox x:Name="amount2" Header=" " TextAlignment="Right" IsReadOnly="true"/>
					<TextBox x:Name="amount3" Header=" " TextAlignment="Right" IsReadOnly="true"/>
					<TextBox x:Name="amount4" Header=" " TextAlignment="Right" IsReadOnly="true"/>
					<TextBox x:Name="amount5" Header=" " TextAlignment="Right" IsReadOnly="true"/>
					<TextBox x:Name="amount6" Header=" " TextAlignment="Right" IsReadOnly="true"/>
					<TextBox x:Name="amount7" Header=" " TextAlignment="Right" IsReadOnly="true"/>
					<TextBox x:Name="amount8" Header=" " TextAlignment="Right" IsReadOnly="true"/>
					<TextBox x:Name="amount9" Header=" " TextAlignment="Right" IsReadOnly="true"/>
					<TextBox x:Name="amount10" Header=" " TextAlignment="Right" IsReadOnly="true"/>
				</StackPanel>
			</StackPanel>


			<StackPanel Orientation="Vertical">
				<StackPanel Orientation="Vertical" Spacing="10">
					<StackPanel Orientation="Horizontal" Spacing="10">
						<TextBox HorizontalAlignment="Left" Header="Mã rập :" x:Name="frameNO" Width="100" IsReadOnly="true"/>
						<TextBox HorizontalAlignment="left" Header="Số lượng tấm lớn:" x:Name="amount" Width="190" TextAlignment="Center" BeforeTextChanging="Amount_BeforeTextChanging"/>
						<!--<TextBlock>							
							<Run Text="Loại giá:"/>
                        </TextBlock>-->
						<ComboBox Header="Loại ván" x:Name="cbbPlankType" Width="100" HorizontalAlignment="Left">
							<ComboBoxItem Content="HP"/>
							<ComboBoxItem Content="MDF"/>
						</ComboBox>
					</StackPanel>
					<TextBox x:Name="txtDescribe" Header="Mô tả" HorizontalAlignment="Left"
                            TextWrapping="Wrap" AcceptsReturn="True" IsSpellCheckEnabled="False" Width="300" IsReadOnly="true"/>
				</StackPanel>

				<StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Spacing="10" Margin="0,10,0,0">
					<CommandBar Background="Transparent" DefaultLabelPosition="Right">
						<AppBarButton x:Name="btnSave" Background="#07af00" Icon="Save" Label="Lưu kho" Click="BtnSave_Click" ToolTipService.ToolTip="Press F1" CornerRadius="10"
                                      IsEnabled="{x:Bind ViewModel.IsLoading, Converter={StaticResource BoolToNegationConverter}, Mode=OneWay}">
							<AppBarButton.KeyboardAccelerators>
								<KeyboardAccelerator Key="F1"/>
							</AppBarButton.KeyboardAccelerators>
						</AppBarButton>
						<AppBarButton Background="#24a6d5" Icon="Refresh" Label="làm mới" Click="BtnReset_Click" ToolTipService.ToolTip="Press F2" CornerRadius="10"
                                      IsEnabled="{x:Bind ViewModel.IsLoading, Converter={StaticResource BoolToNegationConverter}, Mode=OneWay}">
							<AppBarButton.KeyboardAccelerators>
								<KeyboardAccelerator Key="F2"/>
							</AppBarButton.KeyboardAccelerators>
						</AppBarButton>
					</CommandBar>
				</StackPanel>
			</StackPanel>
		</StackPanel>

		<StackPanel Grid.Row="1">
			<controls:DataGrid
                x:Name="PlankGrid"
                MaxHeight="600"
                Width="Auto"
                VerticalAlignment="Top"
                HorizontalAlignment="Left"
                GridLinesVisibility="All"
                CanUserReorderColumns="False"
                CanUserSortColumns="False"
                AutoGenerateColumns="False"
                IsReadOnly="True"
                ScrollViewer.VerticalScrollBarVisibility="Auto"
                ColumnHeaderStyle="{StaticResource CustomHeaderStyle}"
                HorizontalGridLinesBrush="{ThemeResource DataGridBorderColor}"
                VerticalGridLinesBrush="{ThemeResource DataGridBorderColor}"
                BorderThickness="1"
                ItemsSource="{x:Bind ViewModel.FramesSource, Mode=OneWay}"
                SelectionChanged="PlankGrid_SelectionChanged"
                SelectionMode="Single">

				<controls:DataGrid.Resources>
					<SolidColorBrush x:Key="DataGridColumnHeaderBackgroundColor" Color="Transparent" />
				</controls:DataGrid.Resources>

				<controls:DataGrid.Columns>
					<controls:DataGridTextColumn IsReadOnly="True" Header="Mã Rập" Binding="{Binding FrameNO}" Width="Auto">
						<controls:DataGridTextColumn.ElementStyle>
							<Style TargetType="TextBlock">
								<Setter Property="HorizontalAlignment" Value="Stretch"/>
								<Setter Property="TextAlignment" Value="Left"/>
							</Style>
						</controls:DataGridTextColumn.ElementStyle>
					</controls:DataGridTextColumn>

					<controls:DataGridTextColumn IsReadOnly="True" Header="Mô tả" Binding="{Binding Description}" Width="Auto">
						<controls:DataGridTextColumn.ElementStyle>
							<Style TargetType="TextBlock">
								<Setter Property="HorizontalAlignment" Value="Stretch"/>
								<Setter Property="TextAlignment" Value="Left"/>
							</Style>
						</controls:DataGridTextColumn.ElementStyle>
					</controls:DataGridTextColumn>
				</controls:DataGrid.Columns>
			</controls:DataGrid>

			<StackPanel>
				<ProgressRing Grid.Column="1"
                      IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                      Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"
                      Width="60" Height="60"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center" />
			</StackPanel>
		</StackPanel>

	</Grid>
</Page>