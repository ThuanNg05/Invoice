<Page
    x:Class="Invoice.Views.CustomersPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:behaviors="using:Invoice.Behaviors"
    mc:Ignorable="d">

	<Page.Resources>
		<ResourceDictionary>
			<ResourceDictionary.ThemeDictionaries>
				<ResourceDictionary x:Key="Light">
					<SolidColorBrush x:Key="DataGridBorderColor" Color="Black"/>
				</ResourceDictionary>
				<ResourceDictionary x:Key="Dark">
					<SolidColorBrush x:Key="DataGridBorderColor" Color="Gray"/>
				</ResourceDictionary>
			</ResourceDictionary.ThemeDictionaries>

			<Style x:Key="CustomHeaderStyle" TargetType="ContentControl">
				<Setter Property="FontSize" Value="15"/>
				<Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}"/>
				<Setter Property="FontWeight" Value="Bold"/>
				<Setter Property="HorizontalContentAlignment" Value="Center"/>
			</Style>
		</ResourceDictionary>
	</Page.Resources>

	<Grid x:Name="ContentArea">
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="330"/>
			<ColumnDefinition Width="Auto" />
		</Grid.ColumnDefinitions>
		<StackPanel Grid.Column="0" Spacing="10" Margin="0,0,30,0">
			<TextBlock>
				<Run x:Uid="Required_Field" Foreground="Red"/>
				<Run Text="Tên khách hàng"/>
			</TextBlock>
			<TextBox x:Name="txtName" Width="200" HorizontalAlignment="Left" IsSpellCheckEnabled="False"/>

			<TextBlock>
				<Run x:Uid="Required_Field" Foreground="Red"/>
				<Run Text="SĐT"/>
			</TextBlock>
			<TextBox
                x:Name="txtPhoneNo"
                Width="200"
                HorizontalAlignment="Left"
                behaviors:TextBoxInputBehavior.InputType="PhoneNumber"/>

			<TextBlock>
				<Run x:Uid="Required_Field" Foreground="Red"/>
				<Run Text="Loại giá"/>
			</TextBlock>
            <ComboBox x:Name="CmbPriceType" Width="200" HorizontalAlignment="Left">
                <ComboBoxItem Content="Sỉ"/>
                <ComboBoxItem Content="Lẻ"/>
            </ComboBox>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Spacing="10" Margin="0,10,0,0">
				<CommandBar Background="Transparent" DefaultLabelPosition="Right">
					<AppBarButton x:Name="btnAdd" x:Uid="Btn_Add" Background="#07af00"
                                  CornerRadius="10" Icon="Add"
                                  Click="BtnAdd_Click" ToolTipService.ToolTip="Press F1"
                                  Foreground="{ThemeResource SettingsForegroundBrush}"
                                  IsEnabled="{x:Bind ViewModel.IsBusy, Converter={StaticResource BoolToNegationConverter}, Mode=OneWay}">
						<AppBarButton.KeyboardAccelerators>
							<KeyboardAccelerator Key="F1"/>
						</AppBarButton.KeyboardAccelerators>
					</AppBarButton>
					<AppBarButton x:Name="btnUpdate" x:Uid="Btn_Update" Background="#b48b14"
                                  CornerRadius="10" Icon="Edit"
                                  Click="BtnUpdate_Click" ToolTipService.ToolTip="Press F2"
                                  Foreground="{ThemeResource SettingsForegroundBrush}"
                                  IsEnabled="{x:Bind ViewModel.IsBusy, Converter={StaticResource BoolToNegationConverter}, Mode=OneWay}">
						<AppBarButton.KeyboardAccelerators>
							<KeyboardAccelerator Key="F2"/>
						</AppBarButton.KeyboardAccelerators>
					</AppBarButton>
					<AppBarButton x:Name="btnDelete" x:Uid="Btn_Delete" Background="#ff3800"
                                  CornerRadius="10" Icon="Delete"
                                  Click="BtnDelete_Click" ToolTipService.ToolTip="Press F3"
                                  Foreground="{ThemeResource SettingsForegroundBrush}"
                                  IsEnabled="{x:Bind ViewModel.IsBusy, Converter={StaticResource BoolToNegationConverter}, Mode=OneWay}">
						<AppBarButton.KeyboardAccelerators>
							<KeyboardAccelerator Key="F3"/>
						</AppBarButton.KeyboardAccelerators>
					</AppBarButton>
					<AppBarButton x:Name="btnReset" x:Uid="Btn_Reset" Background="#24a6d5"
                                  CornerRadius="10" Icon="Refresh"
                                  Click="BtnReset_Click" ToolTipService.ToolTip="Press F5"
                                  Foreground="{ThemeResource SettingsForegroundBrush}"
                                  IsEnabled="{x:Bind ViewModel.IsBusy, Converter={StaticResource BoolToNegationConverter}, Mode=OneWay}">
						<AppBarButton.KeyboardAccelerators>
							<KeyboardAccelerator Key="F5"/>
						</AppBarButton.KeyboardAccelerators>
					</AppBarButton>
				</CommandBar>
			</StackPanel>
		</StackPanel>
		<StackPanel
            Orientation="Vertical"
            Grid.Column="1">
			<StackPanel Orientation="Horizontal" Margin="0,0,0,10">
				<TextBlock Text="Tìm kiếm : " VerticalAlignment="Center" Margin="0,0,10,0"/>
				<TextBox x:Name="txtSearch" Width="250" TextChanged="txtSearch_TextChanged"/>
			</StackPanel>
			<controls:DataGrid
                x:Name="CustomerGrid"
                MaxHeight="600"
                VerticalAlignment="Top"
                AutoGenerateColumns="False"
                GridLinesVisibility="All"
                IsReadOnly="True"
                SelectionMode="Single"
                CanUserReorderColumns="False"
                CanUserSortColumns="False"
                CanUserResizeColumns="False"
                ColumnHeaderStyle="{StaticResource CustomHeaderStyle}"
                HorizontalGridLinesBrush="{ThemeResource DataGridBorderColor}"
                VerticalGridLinesBrush="{ThemeResource DataGridBorderColor}"
                BorderThickness="1"
                ItemsSource="{x:Bind ViewModel.CustomersCollection, Mode=OneWay}"
                SelectionChanged="CustomerGrid_SelectionChanged">

				<controls:DataGrid.Resources>
					<SolidColorBrush x:Key="DataGridColumnHeaderBackgroundColor" Color="Transparent" />
				</controls:DataGrid.Resources>
				<controls:DataGrid.Columns>
					<controls:DataGridTextColumn Header="Tên" Binding="{Binding Name}" />
					<controls:DataGridTextColumn Header="SĐT" Binding="{Binding Phone}">
						<controls:DataGridTextColumn.ElementStyle>
							<Style TargetType="TextBlock">
								<Setter Property="HorizontalAlignment" Value="Stretch"/>
								<Setter Property="TextAlignment" Value="Right"/>
							</Style>
						</controls:DataGridTextColumn.ElementStyle>
					</controls:DataGridTextColumn>
					<controls:DataGridTextColumn Header="Loại giá" Binding="{Binding PriceGroup}">
						<controls:DataGridTextColumn.ElementStyle>
							<Style TargetType="TextBlock">
								<Setter Property="HorizontalAlignment" Value="Stretch"/>
								<Setter Property="TextAlignment" Value="Center"/>
							</Style>
						</controls:DataGridTextColumn.ElementStyle>
					</controls:DataGridTextColumn>
				</controls:DataGrid.Columns>
			</controls:DataGrid>
		</StackPanel>
	</Grid>
</Page>
