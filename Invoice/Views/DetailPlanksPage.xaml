<Page
    x:Class="Invoice.Views.DetailPlanksPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"    
    mc:Ignorable="d">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="DataGridBorderColor" Color="Black"/>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="DataGridBorderColor" Color="Gray"/>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

            <Style x:Key="CustomHeaderStyle" TargetType="ContentControl">
                <Setter Property="FontSize" Value="15"/>
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="HorizontalContentAlignment" Value="Center"/>
            </Style>
        </ResourceDictionary>
    </Page.Resources>

    <Grid x:Name="ContentArea" Padding="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="16" Margin="0,0,0,16" VerticalAlignment="Bottom">

            <StackPanel Orientation="Vertical">
                <TextBox x:Name="size" Header="Kích thước" TextAlignment="Left" Width="150"/>
            </StackPanel>


            <StackPanel Orientation="Vertical">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Spacing="10" Margin="0,10,0,0">
                    <CommandBar Background="Transparent" DefaultLabelPosition="Right">
                        <AppBarButton x:Name="btnAdd" Background="#07af00" Icon="Add" Label="Thêm" Click="BtnAdd_Click" ToolTipService.ToolTip="Press F1" CornerRadius="10">
                            <AppBarButton.KeyboardAccelerators>
                                <KeyboardAccelerator Key="F1"/>
                            </AppBarButton.KeyboardAccelerators>
                        </AppBarButton>
                        <AppBarButton x:Name="btnDelete" Background="#ff3800" Icon="Delete" Label="Xoá" Click="BtnDelete_Click" ToolTipService.ToolTip="Press F2" CornerRadius="10">
                            <AppBarButton.KeyboardAccelerators>
                                <KeyboardAccelerator Key="F2"/>
                            </AppBarButton.KeyboardAccelerators>
                        </AppBarButton>
                        <AppBarButton Background="#24a6d5" Icon="Refresh" Label="làm mới" Click="BtnReset_Click" ToolTipService.ToolTip="Press F3" CornerRadius="10">
                            <AppBarButton.KeyboardAccelerators>
                                <KeyboardAccelerator Key="F3"/>
                            </AppBarButton.KeyboardAccelerators>
                        </AppBarButton>
                    </CommandBar>
                </StackPanel>
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Row="1">
            <controls:DataGrid
                    x:Name="ListPlankGrid"
                    MaxHeight="600"
                    Width="Auto"
                    VerticalAlignment="Top"                           
                    HorizontalAlignment="Left"
                    GridLinesVisibility="All"
                    CanUserReorderColumns="False"
                    CanUserSortColumns="False"
                    AutoGenerateColumns="False"                           
                    IsReadOnly="True"
                    ScrollViewer.VerticalScrollBarVisibility="Auto"
                    ColumnHeaderStyle="{StaticResource CustomHeaderStyle}"
                    ItemsSource="{x:Bind ViewModel.Planks, Mode=OneWay}"
                    HorizontalGridLinesBrush="{ThemeResource DataGridBorderColor}"
                    VerticalGridLinesBrush="{ThemeResource DataGridBorderColor}"  
                    BorderThickness="1"
                    SelectionChanged="ListPlankGrid_SelectionChanged"
                    SelectionMode="Single">

                <controls:DataGrid.Resources>
                    <SolidColorBrush x:Key="DataGridColumnHeaderBackgroundColor" Color="Transparent" />
                </controls:DataGrid.Resources>

                <controls:DataGrid.Columns>
                    <controls:DataGridTextColumn IsReadOnly="True" Header="Kích thước" Binding="{Binding sizeID}" Width="Auto">
                        <controls:DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                                <Setter Property="TextAlignment" Value="Left"/>
                            </Style>
                        </controls:DataGridTextColumn.ElementStyle>
                    </controls:DataGridTextColumn>

                    <controls:DataGridTextColumn IsReadOnly="True" Header="Tồn kho" Binding="{Binding inventory}" Width="Auto">
                        <controls:DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                                <Setter Property="TextAlignment" Value="Left"/>
                            </Style>
                        </controls:DataGridTextColumn.ElementStyle>
                    </controls:DataGridTextColumn>
                </controls:DataGrid.Columns>
            </controls:DataGrid>

            <ProgressRing Grid.Column="1"
              IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
              Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"
              Width="60" Height="60"
              HorizontalAlignment="Center"
              VerticalAlignment="Center" />
        </StackPanel>
    </Grid>
</Page>