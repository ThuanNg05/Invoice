<Page
    x:Class="Invoice.Views.ProductsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:behaviors="using:Invoice.Behaviors"
    xmlns:converters="using:Invoice.Helpers"
    mc:Ignorable="d">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="DataGridBorderColor" Color="Black"/>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="DataGridBorderColor" Color="Gray"/>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

            <Style x:Key="CustomHeaderStyle" TargetType="ContentControl">
                <Setter Property="FontSize" Value="15"/>
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="HorizontalContentAlignment" Value="Center"/>
            </Style>

            <converters:InventoryToColorConverter x:Key="InventoryColorConverter"/>

            <!-- Method 3: Custom AppBarButton Style to swap Icon and Label -->
            <Style x:Key="RightIconAppBarButtonStyle" TargetType="AppBarButton">
                <Setter Property="Height" Value="40"/>
                <Setter Property="Width" Value="120"/>
                <Setter Property="HorizontalAlignment" Value="Left"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="AppBarButton">
                            <Grid x:Name="Root" Background="{TemplateBinding Background}" CornerRadius="{TemplateBinding CornerRadius}">
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal" />
                                        <VisualState x:Name="PointerOver">
                                            <VisualState.Setters>
                                                <Setter Target="Root.Opacity" Value="0.8"/>
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Pressed">
                                            <VisualState.Setters>
                                                <Setter Target="Root.Opacity" Value="0.6"/>
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Disabled">
                                            <VisualState.Setters>
                                                <Setter Target="Root.Opacity" Value="0.5"/>
                                            </VisualState.Setters>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                                <StackPanel Orientation="Horizontal" Padding="12,0" HorizontalAlignment="Center" Spacing="8">
                                    <TextBlock Text="{TemplateBinding Label}" 
                                               VerticalAlignment="Center" 
                                               Foreground="{TemplateBinding Foreground}"/>
                                    <Viewbox Width="16" Height="16" VerticalAlignment="Center">
                                        <ContentPresenter x:Name="IconContent" Content="{TemplateBinding Icon}" Foreground="{TemplateBinding Foreground}"/>
                                    </Viewbox>
                                </StackPanel>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Page.Resources>
    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                  HorizontalScrollMode="Auto" VerticalScrollMode="Auto" ZoomMode="Disabled">
        <Grid x:Name="ContentArea">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="470"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Margin="0,0,20,0">
                <StackPanel Orientation="Vertical" Margin="0,0,0,10">
                    <StackPanel Orientation="Horizontal">
                        <StackPanel Margin="0,0,10,10">
                            <TextBlock>                                
                                <Run Text="Tên sản phẩm"/>
                            </TextBlock>
                            <TextBox x:Name="txtName" Width="300" HorizontalAlignment="Left" Margin="0,0,0,5"/>
                            <TextBlock Text="Cỡ ván"/>
                            <AutoSuggestBox x:Name="txtSizeID" PlaceholderText="VD: 50x70" Width="300" HorizontalAlignment="Left" 
                                            TextChanged="AutoSuggestBox_TextChanged" SuggestionChosen="AutoSuggestBox_SuggestionChosen"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock>                                
                                <Run Text="Tiền công"/>
                            </TextBlock>
                            <TextBox x:Name="txtWage" Width="140" HorizontalAlignment="Right" behaviors:TextBoxInputBehavior.InputType="Decimal" TextChanged="computeBasePrice"/>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="Giá gốc"/>
                            <TextBox x:Name="txtBasePrice" Width="140" TextAlignment="Right" behaviors:TextBoxInputBehavior.InputType="Decimal"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Giá lẻ"/>
                            <TextBox x:Name="txtPriceOdd" Width="150" TextAlignment="Right" behaviors:TextBoxInputBehavior.InputType="Decimal"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Giá sỉ"/>
                            <TextBox x:Name="txtPriceEven" Width="140" TextAlignment="Right" behaviors:TextBoxInputBehavior.InputType="Decimal"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Vertical" Margin="0,0,10,0" Grid.Column="0">
                        <CommandBar Background="Transparent" DefaultLabelPosition="Right">
                            <AppBarButton x:Name="btnAdd" Label="Thêm" Background="#07af00" Foreground="{ThemeResource SettingsForegroundBrush}"
                                          Style="{StaticResource RightIconAppBarButtonStyle}"
                                          CornerRadius="10" Icon="Add" Click="BtnNew_Click" ToolTipService.ToolTip="Press F1"
                                          IsEnabled="{x:Bind ViewModel.IsBusy, Converter={StaticResource BoolToNegationConverter}, Mode=OneWay}">
                                <AppBarButton.KeyboardAccelerators>
                                    <KeyboardAccelerator Key="F1"/>
                                </AppBarButton.KeyboardAccelerators>
                            </AppBarButton>
                        </CommandBar>
                        <CommandBar Background="Transparent" DefaultLabelPosition="Right">
                            <AppBarButton x:Name="btnUpdate" Label="Cập nhật" Background="#b48b14" Foreground="{ThemeResource SettingsForegroundBrush}"
                                          Style="{StaticResource RightIconAppBarButtonStyle}"
                                          CornerRadius="10" Icon="Edit" Click="BtnUpdate_Click" ToolTipService.ToolTip="Press F2">
                                <AppBarButton.KeyboardAccelerators>
                                    <KeyboardAccelerator Key="F2"/>
                                </AppBarButton.KeyboardAccelerators>
                            </AppBarButton>
                        </CommandBar>
                        <CommandBar Background="Transparent" DefaultLabelPosition="Right">
                            <AppBarButton x:Name="btnDelete" Label="Xóa" Background="#ff3800" Foreground="{ThemeResource SettingsForegroundBrush}"
                                          Style="{StaticResource RightIconAppBarButtonStyle}"
                                          CornerRadius="10" Icon="Delete" Click="BtnDelete_Click" ToolTipService.ToolTip="Press F3">
                                <AppBarButton.KeyboardAccelerators>
                                    <KeyboardAccelerator Key="F3"/>
                                </AppBarButton.KeyboardAccelerators>
                            </AppBarButton>
                        </CommandBar>
                        <CommandBar Background="Transparent" DefaultLabelPosition="Right">
                            <AppBarButton x:Name="btnReset" Label="Đặt lại" Background="#24a6d5" Foreground="{ThemeResource SettingsForegroundBrush}"
                                          Style="{StaticResource RightIconAppBarButtonStyle}"
                                          CornerRadius="10" Icon="Refresh" Click="BtnReset_Click" ToolTipService.ToolTip="Press F5">
                                <AppBarButton.KeyboardAccelerators>
                                    <KeyboardAccelerator Key="F5"/>
                                </AppBarButton.KeyboardAccelerators>
                            </AppBarButton>
                        </CommandBar>
                    </StackPanel>
                    <Grid RowSpacing="4" HorizontalAlignment="Stretch" Grid.Column="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="100" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Column 1 -->
                        <TextBox Margin="0,0,10,4" behaviors:TextBoxInputBehavior.InputType="Decimal" TextChanged="computeBasePrice" TextAlignment="Right" Grid.Row="0" Grid.Column="0" x:Name="txtKieng" Header="Kiếng " />
                        <TextBox Margin="0,0,10,4" behaviors:TextBoxInputBehavior.InputType="Decimal" TextChanged="computeBasePrice" TextAlignment="Right" Grid.Row="1" Grid.Column="0" x:Name="txtNhL" Header="Nhựa lớn "/>
                        <TextBox Margin="0,0,10,4" behaviors:TextBoxInputBehavior.InputType="Decimal" TextChanged="computeBasePrice" TextAlignment="Right" Grid.Row="2" Grid.Column="0" x:Name="txtNhN" Header="Nhựa nhỏ "/>
                        <TextBox Margin="0,0,10,4" behaviors:TextBoxInputBehavior.InputType="Decimal" TextChanged="computeBasePrice" TextAlignment="Right" Grid.Row="3" Grid.Column="0" x:Name="txtG_l" Header="Gỗ lớn "  />
                        <TextBox Margin="0,0,10,4" behaviors:TextBoxInputBehavior.InputType="Decimal" TextChanged="computeBasePrice" TextAlignment="Right" Grid.Row="4" Grid.Column="0" x:Name="txtG_n" Header="Gỗ nhỏ "  />
                        <TextBox Margin="0,0,10,4" behaviors:TextBoxInputBehavior.InputType="Decimal" TextChanged="computeBasePrice" TextAlignment="Right" Grid.Row="5" Grid.Column="0" x:Name="txtDl" Header="Đen lớn "  />
                        <TextBox Margin="0,0,10,0" behaviors:TextBoxInputBehavior.InputType="Decimal" TextChanged="computeBasePrice" TextAlignment="Right" Grid.Row="6" Grid.Column="0" x:Name="txtHau" Header="Hậu "      />

                        <!-- Column 2 -->
                        <TextBox Margin="0,0,10,4" behaviors:TextBoxInputBehavior.InputType="Decimal" TextChanged="computeBasePrice" TextAlignment="Right" Grid.Row="0" Grid.Column="1" x:Name="txtLua" Header="Lụa "/>
                        <TextBox Margin="0,0,10,4" behaviors:TextBoxInputBehavior.InputType="Decimal" TextChanged="computeBasePrice" TextAlignment="Right" Grid.Row="1" Grid.Column="1" x:Name="txtKt" Header="Kim tuyến "/>
                        <TextBox Margin="0,0,10,4" behaviors:TextBoxInputBehavior.InputType="Decimal" TextChanged="computeBasePrice" TextAlignment="Right" Grid.Row="2" Grid.Column="1" x:Name="txtOc" Header="Ốc "/>
                        <TextBox Margin="0,0,10,4" behaviors:TextBoxInputBehavior.InputType="Decimal" TextChanged="computeBasePrice" TextAlignment="Right" Grid.Row="3" Grid.Column="1" x:Name="txtNhom" Header="Nhôm "/>
                        <TextBox Margin="0,0,10,4" behaviors:TextBoxInputBehavior.InputType="Decimal" TextChanged="computeBasePrice" TextAlignment="Right" Grid.Row="4" Grid.Column="1" x:Name="txt7f" Header="Gỗ 7F "/>
                        <TextBox Margin="0,0,10,4" behaviors:TextBoxInputBehavior.InputType="Decimal" TextChanged="computeBasePrice" TextAlignment="Right" Grid.Row="5" Grid.Column="1" x:Name="txt2D" Header="2D "/>
                        <TextBox Margin="0,0,10,0" behaviors:TextBoxInputBehavior.InputType="Decimal" TextChanged="computeBasePrice" TextAlignment="Right" Grid.Row="6" Grid.Column="1" x:Name="txtDecal" Header="Decal "/>

                        <!-- Column 3-->
                        <TextBox Margin="0,0,0,4" TextAlignment="Right" Grid.Row="0" Grid.Column="2" x:Name="txtMDFodd" Header="MDF Lẻ "/>
                        <TextBox Margin="0,0,0,4" TextAlignment="Right" Grid.Row="1" Grid.Column="2" x:Name="txtMDFeven" Header="MDF Sỉ "/>
                        <TextBox Margin="0,0,0,4" TextAlignment="Right" Grid.Row="2" Grid.Column="2" x:Name="txtHPodd" Header="HP Lẻ "/>
                        <TextBox Margin="0,0,0,4" TextAlignment="Right" Grid.Row="3" Grid.Column="2" x:Name="txtHPeven" Header="HP Sỉ "/>
                        <TextBox Margin="0,0,0,4" TextAlignment="Right" Grid.Row="4" Grid.Column="2" x:Name="txtTG" Header="TG "/>
                        <TextBox Margin="0,0,0,4" TextAlignment="Right" Grid.Row="5" Grid.Column="2" x:Name="txtHoanh" Header="Hoành "/>
                        <TextBox Margin="0,0,0,0" TextAlignment="Right" Grid.Row="6" Grid.Column="2" x:Name="txtLieng" Header="Liễng "/>
                    </Grid>
                </Grid>
            </StackPanel>

            <StackPanel
                Grid.Column="1"
                Orientation="Vertical">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="Tìm kiếm : " VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox x:Name="txtSearch" Width="250" TextChanged="txtSearch_TextChanged" />
                </StackPanel>

                <controls:DataGrid
                    x:Name="ProductGrid" MaxHeight="600"
                    VerticalAlignment="Top" AutoGenerateColumns="False" GridLinesVisibility="All"            
                    IsReadOnly="True" SelectionMode="Single" CanUserReorderColumns="False"
                    CanUserSortColumns="False" CanUserResizeColumns="False" ScrollViewer.VerticalScrollBarVisibility="Auto"
                    RowHeight="35"
                    ColumnHeaderStyle="{StaticResource CustomHeaderStyle}" ItemsSource="{x:Bind ViewModel.Source, Mode=OneWay}"
                    HorizontalGridLinesBrush="{ThemeResource DataGridBorderColor}"
                    VerticalGridLinesBrush="{ThemeResource DataGridBorderColor}"                      
                    BorderThickness="1"
                    LoadingRow="ProductGrid_LoadingRow"
                    SelectionChanged="ProductGrid_SelectionChanged">

                    <controls:DataGrid.Resources>
                        <SolidColorBrush x:Key="DataGridColumnHeaderBackgroundColor" Color="Transparent" />
                    </controls:DataGrid.Resources>
                    <controls:DataGrid.Columns>
                        <controls:DataGridTextColumn Header="Tên SP" Width="200" Binding="{Binding Name}" />
                        <controls:DataGridTextColumn Header="Giá gốc" Binding="{Binding BasePrice}">
                            <controls:DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Stretch"/>
                                    <Setter Property="TextAlignment" Value="Right"/>
                                </Style>
                            </controls:DataGridTextColumn.ElementStyle>
                        </controls:DataGridTextColumn>
                        <controls:DataGridTextColumn Header="Giá lẻ" Binding="{Binding PriceOdd}">
                            <controls:DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Stretch"/>
                                    <Setter Property="TextAlignment" Value="Right"/>
                                </Style>
                            </controls:DataGridTextColumn.ElementStyle>
                        </controls:DataGridTextColumn>
                        <controls:DataGridTextColumn Header="Giá sỉ" Binding="{Binding PriceEven}">
                            <controls:DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Stretch"/>
                                    <Setter Property="TextAlignment" Value="Right"/>
                                </Style>
                            </controls:DataGridTextColumn.ElementStyle>
                        </controls:DataGridTextColumn>
                        <controls:DataGridTemplateColumn Header="Tồn kho">
                            <controls:DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="{Binding Converter={StaticResource InventoryColorConverter}}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                        <TextBlock Text="{Binding Inventory}" 
                                                   TextAlignment="Right" 
                                                   VerticalAlignment="Center" 
                                                   Padding="10,0"
                                                   HorizontalAlignment="Stretch"/>
                                    </Border>
                                </DataTemplate>
                            </controls:DataGridTemplateColumn.CellTemplate>
                        </controls:DataGridTemplateColumn>
                    </controls:DataGrid.Columns>
                </controls:DataGrid>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
