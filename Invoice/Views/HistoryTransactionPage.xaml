<Page
    x:Class="Invoice.Views.HistoryTransactionPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:converters="using:Invoice.Helpers"
    mc:Ignorable="d">

	<Page.Resources>
		<ResourceDictionary>
			<ResourceDictionary.ThemeDictionaries>
				<ResourceDictionary x:Key="Light">
					<SolidColorBrush x:Key="DataGridBorderColor" Color="Black"/>
				</ResourceDictionary>
				<ResourceDictionary x:Key="Dark">
					<SolidColorBrush x:Key="DataGridBorderColor" Color="Gray"/>
				</ResourceDictionary>
			</ResourceDictionary.ThemeDictionaries>

			<Style x:Key="CustomHeaderStyle" TargetType="ContentControl">
				<Setter Property="FontSize" Value="15"/>
				<Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}"/>
				<Setter Property="FontWeight" Value="Bold"/>
				<Setter Property="HorizontalContentAlignment" Value="Center"/>
			</Style>

			<converters:DateTimeFormatter x:Key="DateFormat"/>
		</ResourceDictionary>
	</Page.Resources>

	<Grid x:Name="ContentArea" Padding="20">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>

		<StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="16" Margin="0,0,0,16" VerticalAlignment="Bottom">

			<StackPanel Spacing="4">
				<TextBlock Text="Từ" Style="{ThemeResource CaptionTextBlockStyle}" FontSize="15" FontStyle="Italic" FontWeight="Bold"/>
				<DatePicker SelectedDate="{x:Bind ViewModel.StartDate, Mode=TwoWay}"
                            Language="vi-VN"
                            Width="Auto"
                            VerticalAlignment="Center"
                            FontSize="15"/>
			</StackPanel>

			<StackPanel Spacing="4">
				<TextBlock Text="Đến" Style="{ThemeResource CaptionTextBlockStyle}" FontSize="15" FontStyle="Italic" FontWeight="Bold"/>
				<DatePicker SelectedDate="{x:Bind ViewModel.EndDate, Mode=TwoWay}"
                            Language="vi-VN"
                            Width="Auto"
                            VerticalAlignment="Center"
                            FontSize="15"/>
			</StackPanel>

			<StackPanel Spacing="4">
				<TextBlock Text="Nguồn" Style="{ThemeResource CaptionTextBlockStyle}" FontSize="15" FontStyle="Italic" FontWeight="Bold"/>
				<ComboBox x:Name="cmbSource" 
                          ItemsSource="{x:Bind ViewModel.SourceTypes}"
                          SelectedItem="{x:Bind ViewModel.SelectedSourceType, Mode=TwoWay}"
                          PlaceholderText="Chọn nguồn..."
                          Width="150" Height="32" VerticalAlignment="Bottom"/>
			</StackPanel>

			<StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Spacing="10" Margin="0,10,0,0">
				<CommandBar Background="Transparent" DefaultLabelPosition="Right" >
					<AppBarButton Label="Tìm kiếm" Background="#b48b14" Foreground="{ThemeResource SettingsForegroundBrush}"
                                  Click="BtnQuery_Click" ToolTipService.ToolTip="Press F1" CornerRadius="10">
						<AppBarButton.Icon>
							<FontIcon Glyph="&#xE721;"/>
						</AppBarButton.Icon>
						<AppBarButton.KeyboardAccelerators>
							<KeyboardAccelerator Key="F1"/>
						</AppBarButton.KeyboardAccelerators>
					</AppBarButton>
					<AppBarButton x:Uid="Btn_Reset" Background="#24a6d5" Icon="Refresh" Foreground="{ThemeResource SettingsForegroundBrush}"
                                  Click="BtnReset_Click" ToolTipService.ToolTip="Press F2" CornerRadius="10">
						<AppBarButton.KeyboardAccelerators>
							<KeyboardAccelerator Key="F2"/>
						</AppBarButton.KeyboardAccelerators>
					</AppBarButton>
				</CommandBar>
			</StackPanel>
		</StackPanel>

		<controls:DataGrid Grid.Row="1"
                           MaxHeight="600"
                           Width="Auto"
                           VerticalAlignment="Top"
                           GridLinesVisibility="All"
                           CanUserReorderColumns="False"
                           CanUserSortColumns="False"
                           AutoGenerateColumns="False"
                           IsReadOnly="True"
                           RowHeight="35"
                           ScrollViewer.VerticalScrollBarVisibility="Auto"
                           ColumnHeaderStyle="{StaticResource CustomHeaderStyle}"
                           HorizontalGridLinesBrush="{ThemeResource DataGridBorderColor}"
                           VerticalGridLinesBrush="{ThemeResource DataGridBorderColor}"
                           BorderThickness="1"
                           ItemsSource="{x:Bind ViewModel.Source, Mode=OneWay}"
                           SelectionMode="Single">

			<controls:DataGrid.Resources>
				<SolidColorBrush x:Key="DataGridColumnHeaderBackgroundColor" Color="Transparent" />
			</controls:DataGrid.Resources>

			<controls:DataGrid.Columns>
				<controls:DataGridTextColumn Header="Ngày" Binding="{Binding Date, Converter={StaticResource DateFormat}, ConverterParameter='dd/MM/yyyy'}">
					<controls:DataGridTextColumn.ElementStyle>
						<Style TargetType="TextBlock">
							<Setter Property="HorizontalAlignment" Value="Stretch"/>
							<Setter Property="TextAlignment" Value="Left"/>
						</Style>
					</controls:DataGridTextColumn.ElementStyle>
				</controls:DataGridTextColumn>

				<controls:DataGridTextColumn Header="Loại" Binding="{Binding TransactionType}">
					<controls:DataGridTextColumn.ElementStyle>
						<Style TargetType="TextBlock">
							<Setter Property="HorizontalAlignment" Value="Stretch"/>
							<Setter Property="TextAlignment" Value="Center"/>
						</Style>
					</controls:DataGridTextColumn.ElementStyle>
				</controls:DataGridTextColumn>

				<controls:DataGridTextColumn Header="Tên SP/NL" Binding="{Binding ProductName}" Width="250">
					<controls:DataGridTextColumn.ElementStyle>
						<Style TargetType="TextBlock">
							<Setter Property="HorizontalAlignment" Value="Stretch"/>
							<Setter Property="TextAlignment" Value="Left"/>
						</Style>
					</controls:DataGridTextColumn.ElementStyle>
				</controls:DataGridTextColumn>

				<controls:DataGridTextColumn Header="Số lượng" Binding="{Binding Amount}">
					<controls:DataGridTextColumn.ElementStyle>
						<Style TargetType="TextBlock">
							<Setter Property="HorizontalAlignment" Value="Stretch"/>
							<Setter Property="TextAlignment" Value="Center"/>
						</Style>
					</controls:DataGridTextColumn.ElementStyle>
				</controls:DataGridTextColumn>

				<controls:DataGridTextColumn Header="Ghi chú" Binding="{Binding Note}" Width="*">
					<controls:DataGridTextColumn.ElementStyle>
						<Style TargetType="TextBlock">
							<Setter Property="HorizontalAlignment" Value="Stretch"/>
							<Setter Property="TextAlignment" Value="Left"/>
						</Style>
					</controls:DataGridTextColumn.ElementStyle>
				</controls:DataGridTextColumn>
			</controls:DataGrid.Columns>
		</controls:DataGrid>
	</Grid>
</Page>
