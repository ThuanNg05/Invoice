<Page
    x:Class="Invoice.Views.IOActionsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:primitives="using:CommunityToolkit.WinUI.UI.Controls.Primitives"    
    mc:Ignorable="d">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="DataGridBorderColor" Color="Black"/>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="DataGridBorderColor" Color="Gray"/>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

            <Style x:Key="CustomHeaderStyle" TargetType="ContentControl">
                <Setter Property="FontSize" Value="15"/>
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="HorizontalContentAlignment" Value="Center"/>
            </Style>
        </ResourceDictionary>
    </Page.Resources>

    <Grid Padding="12" RowSpacing="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Margin="0,0,400,0"
                BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" BorderThickness="1" Padding="15" CornerRadius="8" Background="{ThemeResource LayerFillColorDefaultBrush}">
            <Grid ColumnSpacing="20" RowSpacing="15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBox x:Uid="IOActions_ProductID" 
                         x:Name="txtID"
                         IsEnabled="{x:Bind ViewModel.IsBusy, Converter={StaticResource BoolToNegationConverter}, Mode=OneWay}"
                         IsReadOnly="True" Grid.Row="0" Grid.Column="0"/>

                <TextBox x:Uid="IOActions_ProductName" 
                         x:Name="txtName"
                         IsEnabled="{x:Bind ViewModel.IsBusy, Converter={StaticResource BoolToNegationConverter}, Mode=OneWay}"
                         IsReadOnly="True" Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2"/>

                <TextBox x:Uid="IOActions_Inventory" 
                         x:Name="txtInventory"
                         IsEnabled="{x:Bind ViewModel.IsBusy, Converter={StaticResource BoolToNegationConverter}, Mode=OneWay}"
                         IsReadOnly="True" Grid.Row="1" Grid.Column="0"/>

                <TextBox x:Uid="IOActions_Amount" 
                         x:Name="txtAmount"
                         IsEnabled="{x:Bind ViewModel.IsBusy, Converter={StaticResource BoolToNegationConverter}, Mode=OneWay}"
                         BeforeTextChanging="txtAmount_BeforeTextChanging"
                         Grid.Row="1" Grid.Column="1"/>

                <ComboBox x:Name="cmbType" x:Uid="IOActions_ActionType" HorizontalAlignment="Stretch" Grid.Row="1" Grid.Column="2">
                    <x:String>Nhập kho</x:String>
                    <x:String>Xuất kho</x:String>
                </ComboBox>


                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0" Spacing="10" Grid.ColumnSpan="3" Grid.Row="2">
                    <AppBarButton x:Name="btnAdd" x:Uid="Btn_Save" Background="#07af00"
                                  IsEnabled="{x:Bind ViewModel.IsBusy, Converter={StaticResource BoolToNegationConverter}, Mode=OneWay}"
                                  CornerRadius="10" Icon="Add" Foreground="{ThemeResource SettingsForegroundBrush}"
                                  Click="BtnAddProduct_Click" ToolTipService.ToolTip="Press F1">
                        <AppBarButton.KeyboardAccelerators>
                            <KeyboardAccelerator Key="F1"/>
                        </AppBarButton.KeyboardAccelerators>
                    </AppBarButton>
                    <AppBarButton x:Name="btnEdit" x:Uid="Btn_Update" Background="#6514db"
                                  Foreground="{ThemeResource SettingsForegroundBrush}"
                                  CornerRadius="10" Icon="Edit" Click="BtnEdit_Click" ToolTipService.ToolTip="Press F2">
                        <AppBarButton.KeyboardAccelerators>
                            <KeyboardAccelerator Key="F2"/>
                        </AppBarButton.KeyboardAccelerators>
                    </AppBarButton>
                    <AppBarButton x:Name="btnDelete" x:Uid="Btn_Delete"
                                  Foreground="{ThemeResource SettingsForegroundBrush}"
                                  Background="#ff3800" CornerRadius="10" Icon="Delete" Click="BtnDelete_Click" ToolTipService.ToolTip="Press F3">
                        <AppBarButton.KeyboardAccelerators>
                            <KeyboardAccelerator Key="F3"/>
                        </AppBarButton.KeyboardAccelerators>
                    </AppBarButton>
                    <AppBarButton x:Uid="Btn_Reset" Background="#b48b14" Foreground="{ThemeResource SettingsForegroundBrush}"
                                  IsEnabled="{x:Bind ViewModel.IsBusy, Converter={StaticResource BoolToNegationConverter}, Mode=OneWay}"
                                  CornerRadius="10" Icon="Refresh" Click="BtnReset_Click" ToolTipService.ToolTip="Press F5">
                        <AppBarButton.KeyboardAccelerators>
                            <KeyboardAccelerator Key="F5"/>
                        </AppBarButton.KeyboardAccelerators>
                    </AppBarButton>
                    <AppBarButton x:Name="btnSave" x:Uid="Btn_Save" Background="#516dcf" Foreground="{ThemeResource SettingsForegroundBrush}"
                                  IsEnabled="{x:Bind ViewModel.IsBusy, Converter={StaticResource BoolToNegationConverter}, Mode=OneWay}"
                                  CornerRadius="10" Icon="Save" Click="BtnSave_Click" ToolTipService.ToolTip="Press F4">
                        <AppBarButton.KeyboardAccelerators>
                            <KeyboardAccelerator Key="F4"/>
                        </AppBarButton.KeyboardAccelerators>
                    </AppBarButton>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2" ColumnSpacing="10">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock x:Uid="Customers_Search" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBox x:Name="txtSearch"
                         IsEnabled="{x:Bind ViewModel.IsBusy, Converter={StaticResource BoolToNegationConverter}, Mode=OneWay}"
                         Width="250" TextChanged="txtSearch_TextChanged" />
            </StackPanel>
        </Grid>

        <ProgressRing Grid.Row="3"
              IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}"
              Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"
              Width="60" Height="60"
              HorizontalAlignment="Center"
              VerticalAlignment="Center" />

        <Grid Grid.Row="3" ColumnSpacing="15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock x:Uid="IOActions_List_Source" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,0,0,5"/>

                <controls:DataGrid Grid.Row="1"
                    x:Name="SourceDataGrid"
                    ItemsSource="{x:Bind ViewModel.SourceList, Mode=OneWay}"
                    SelectionChanged="SourceGrid_SelectionChanged" SelectionMode="Single"
                    HorizontalGridLinesBrush="{ThemeResource DataGridBorderColor}"
                    VerticalGridLinesBrush="{ThemeResource DataGridBorderColor}"                
                    BorderThickness="1"
                    CanUserReorderColumns="False" CanUserResizeColumns="False" CanUserSortColumns="False"
                    AutoGenerateColumns="False" IsReadOnly="True" GridLinesVisibility="All">

                    <controls:DataGrid.Resources>
                        <Style TargetType="primitives:DataGridColumnHeader">
                            <Setter Property="FontSize" Value="16"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}"/>
                            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}"/>
                            <Setter Property="Padding" Value="10,5,10,5"/>
                        </Style>
                    </controls:DataGrid.Resources>

                    <controls:DataGrid.Columns>
                        <controls:DataGridTextColumn Header="ID" Binding="{Binding ProductID}" Visibility="Collapsed"/>
                        <controls:DataGridTextColumn x:Uid="Materials_Grid_Name" Binding="{Binding Name}" Width="*"/>
                        <controls:DataGridTextColumn x:Uid="Materials_Grid_Inventory" Binding="{Binding Inventory}"/>
                    </controls:DataGrid.Columns>
                </controls:DataGrid>
            </Grid>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock x:Uid="IOActions_List_Pending" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,0,0,5"/>

                <controls:DataGrid Grid.Row="1"
                    x:Name="TransactionDataGrid"
                    ItemsSource="{x:Bind ViewModel.TransactionList, Mode=OneWay}"
                    CanUserReorderColumns="False" CanUserResizeColumns="False" CanUserSortColumns="False"
                    SelectionChanged="TransactionGrid_SelectionChanged" SelectionMode="Single"
                    HorizontalGridLinesBrush="{ThemeResource DataGridBorderColor}"
                    VerticalGridLinesBrush="{ThemeResource DataGridBorderColor}"                
                    BorderThickness="1"
                    AutoGenerateColumns="False" IsReadOnly="True" GridLinesVisibility="All">

                    <controls:DataGrid.Resources>
                        <Style TargetType="primitives:DataGridColumnHeader">
                            <Setter Property="FontSize" Value="16"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}"/>
                            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}"/>
                            <Setter Property="Padding" Value="10,5,10,5"/>
                        </Style>
                    </controls:DataGrid.Resources>

                    <controls:DataGrid.Columns>
                        <controls:DataGridTextColumn Header="ID" Binding="{Binding ProductID}"/>
                        <controls:DataGridTextColumn x:Uid="Customers_Grid_Name" Binding="{Binding Name}" Width="*"/>
                        <controls:DataGridTextColumn x:Uid="History_Grid_Amount" Binding="{Binding Amount}"/>
                        <controls:DataGridTextColumn x:Uid="IOActions_ActionType" Binding="{Binding ActionType}"/>
                    </controls:DataGrid.Columns>
                </controls:DataGrid>
            </Grid>
        </Grid>
    </Grid>
</Page>
