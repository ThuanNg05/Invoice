<Page
    x:Class="Invoice.Views.ProductSelectionPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:behaviors="using:Invoice.Behaviors"
    xmlns:converters="using:Invoice.Helpers"
    Background="#272727"
    mc:Ignorable="d">

    <Page.Resources>
        <Style x:Key="CustomHeaderStyle" TargetType="ContentControl">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="#272727"/>
        </Style>

        <converters:InventoryToColorConverter x:Key="InventoryColorConverter"/>
    </Page.Resources>
    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                  HorizontalScrollMode="Auto" VerticalScrollMode="Auto" ZoomMode="Disabled">
        <Grid x:Name="ContentArea">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="400"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Margin="50">
                <StackPanel Orientation="Vertical" Spacing="10">
                    <TextBlock>
                        <Run Text="(*) " Foreground="Red"/>
                        <Run Text="Tên SP:"/>
                    </TextBlock>
                    <TextBox x:Name="txtName" Width="300" HorizontalAlignment="Left"/>
                    <TextBlock>   
                        <Run Text="(*) " Foreground="Red"/>
                        <Run Text="Đơn Giá :"/>
                    </TextBlock>
                    <TextBox x:Name="txtBasePrice" Width="140" TextAlignment="Right"                             
                             TextChanged="Input_TextChanged"
                             HorizontalAlignment="Left"/>
                    <TextBlock>                                                        
                        <Run Text="Số lượng :"/>
                    </TextBlock>
                    <TextBox x:Name="txtAmount" Width="140" TextAlignment="Right"
                             behaviors:TextBoxInputBehavior.InputType="Numeric"
                             TextChanged="Input_TextChanged"
                             HorizontalAlignment="Left"/>
                    <TextBlock>                                
                        <Run Text="Thành tiền :"/>
                    </TextBlock>
                    <TextBox x:Name="txtTotal" Width="140" TextAlignment="Right" IsReadOnly="True" HorizontalAlignment="Left"/>
                    <TextBlock>                                
                        <Run Text="Ghi chú :"/>
                    </TextBlock>
                    <TextBox x:Name="txtNote" IsSpellCheckEnabled="False" 
                            AcceptsReturn="True" MinWidth="240" Width="240" 
                             TextAlignment="Left" Height="100" 
                             PlaceholderText="Ghi chú..." HorizontalAlignment="Left" 
                             TextWrapping="Wrap"/>
                </StackPanel>
                <CommandBar Background="Transparent" DefaultLabelPosition="Right" HorizontalAlignment="Left" Margin="-5,10,0,0">
                    <AppBarButton x:Name="btnAdd" Background="#07af00" Icon="Add" Label="Thêm" Click="BtnAdd_Click"
                                  CornerRadius="10" ToolTipService.ToolTip="Press F1">
                        <AppBarButton.KeyboardAccelerators>
                            <KeyboardAccelerator Key="F1"/>
                        </AppBarButton.KeyboardAccelerators>
                    </AppBarButton>
                    <AppBarButton x:Name="btnReset" Background="#24a6d5" Icon="Refresh" Label="Đặt lại" Click="BtnReset_Click"
                                  CornerRadius="10" ToolTipService.ToolTip="Press F2">
                        <AppBarButton.KeyboardAccelerators>
                            <KeyboardAccelerator Key="F2"/>
                        </AppBarButton.KeyboardAccelerators>
                    </AppBarButton>
                </CommandBar>
            </StackPanel>
            <StackPanel
                Grid.Column="1"
                Margin="0,50,0,0"
                Orientation="Vertical">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock VerticalAlignment="Center" Margin="0,0,10,0">                        
                        <Run Text="Tìm kiếm :"/>
                    </TextBlock>
                    <TextBox x:Name="txtSearch" Width="250" TextChanged="txtSearch_TextChanged" PlaceholderText="Tìm theo Mã SP hoặc Tên SP..."/>
                </StackPanel>

                <controls:DataGrid
                x:Name="ProductGrid"                
                MaxHeight="600"
                VerticalAlignment="Top"
                AutoGenerateColumns="False"            
                GridLinesVisibility="All"            
                IsReadOnly="True"
                SelectionMode="Single"
                LoadingRow="ProductGrid_LoadingRow"
                CanUserReorderColumns="False"
                CanUserSortColumns="False"            
                CanUserResizeColumns="False"
                ScrollViewer.VerticalScrollBarVisibility="Auto"
                ColumnHeaderStyle="{StaticResource CustomHeaderStyle}"
                ItemsSource="{x:Bind ViewModel.Source, Mode=OneWay}"
                SelectionChanged="ProductGrid_SelectionChanged">
                    <controls:DataGrid.Resources>
                        <SolidColorBrush x:Key="DataGridColumnHeaderBackgroundColor" Color="Transparent" />
                    </controls:DataGrid.Resources>
                    <controls:DataGrid.Columns>
                        <controls:DataGridTextColumn Width="200" Binding="{Binding Name}" Header="Tên SP" />
                        <controls:DataGridTextColumn Binding="{Binding BasePrice}" Header="Giá Gốc">
                            <controls:DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Stretch"/>
                                    <Setter Property="TextAlignment" Value="Right"/>
                                </Style>
                            </controls:DataGridTextColumn.ElementStyle>
                        </controls:DataGridTextColumn>
                        <controls:DataGridTextColumn Binding="{Binding PriceOdd}" Header="Giá Lẻ">
                            <controls:DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Stretch"/>
                                    <Setter Property="TextAlignment" Value="Right"/>
                                </Style>
                            </controls:DataGridTextColumn.ElementStyle>
                        </controls:DataGridTextColumn>
                        <controls:DataGridTextColumn Binding="{Binding PriceEven}" Header="Giá Sỉ">
                            <controls:DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Stretch"/>
                                    <Setter Property="TextAlignment" Value="Right"/>
                                </Style>
                            </controls:DataGridTextColumn.ElementStyle>
                        </controls:DataGridTextColumn>
                        <controls:DataGridTemplateColumn Header="Tồn kho">
                            <controls:DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="{Binding Converter={StaticResource InventoryColorConverter}}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                        <TextBlock Text="{Binding Inventory}" 
                                                   TextAlignment="Right" 
                                                   VerticalAlignment="Center" 
                                                   Padding="10,0"
                                                   HorizontalAlignment="Stretch"/>
                                    </Border>
                                </DataTemplate>
                            </controls:DataGridTemplateColumn.CellTemplate>
                        </controls:DataGridTemplateColumn>
                    </controls:DataGrid.Columns>
                </controls:DataGrid>
                <ProgressRing
                      IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}"
                      Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"
                      Width="60" Height="60"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center" />
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>