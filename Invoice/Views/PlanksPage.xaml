<Page
    x:Class="Invoice.Views.PlanksPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    mc:Ignorable="d">

	<Page.Resources>
		<ResourceDictionary>
			<ResourceDictionary.ThemeDictionaries>
				<ResourceDictionary x:Key="Light">
					<SolidColorBrush x:Key="DataGridBorderColor" Color="Black"/>
				</ResourceDictionary>
				<ResourceDictionary x:Key="Dark">
					<SolidColorBrush x:Key="DataGridBorderColor" Color="Gray"/>
				</ResourceDictionary>
			</ResourceDictionary.ThemeDictionaries>

			<Style x:Key="CustomHeaderStyle" TargetType="ContentControl">
				<Setter Property="FontSize" Value="15"/>
				<Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}"/>
				<Setter Property="FontWeight" Value="Bold"/>
				<Setter Property="HorizontalContentAlignment" Value="Center"/>
			</Style>
		</ResourceDictionary>
	</Page.Resources>

	<Grid x:Name="ContentArea" Padding="20">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>

		<StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="16" Margin="0,0,0,16" VerticalAlignment="Bottom">

			<StackPanel Orientation="Vertical" Spacing="10">
				<StackPanel Orientation="Horizontal" Spacing="10">
					<TextBox x:Name="size1" Header="Size 1" TextAlignment="Left"/>
					<TextBox x:Name="size2" Header="Size 2" TextAlignment="Left"/>
					<TextBox x:Name="size3" Header="Size 3" TextAlignment="Left"/>
					<TextBox x:Name="size4" Header="Size 4" TextAlignment="Left"/>
					<TextBox x:Name="size5" Header="Size 5" TextAlignment="Left"/>
					<TextBox x:Name="size6" Header="Size 6" TextAlignment="Left"/>
					<TextBox x:Name="size7" Header="Size 7" TextAlignment="Left"/>
					<TextBox x:Name="size8" Header="Size 8" TextAlignment="Left"/>
					<TextBox x:Name="size9" Header="Size 9" TextAlignment="Left"/>
					<TextBox x:Name="size10" Header="Size 10" TextAlignment="Left"/>
				</StackPanel>

				<StackPanel Orientation="Horizontal" Spacing="10">
					<TextBox x:Name="amount1" TextAlignment="Right" BeforeTextChanging="Amount_BeforeTextChanging"/>
					<TextBox x:Name="amount2" TextAlignment="Right" BeforeTextChanging="Amount_BeforeTextChanging"/>
					<TextBox x:Name="amount3" TextAlignment="Right" BeforeTextChanging="Amount_BeforeTextChanging"/>
					<TextBox x:Name="amount4" TextAlignment="Right" BeforeTextChanging="Amount_BeforeTextChanging"/>
					<TextBox x:Name="amount5" TextAlignment="Right" BeforeTextChanging="Amount_BeforeTextChanging"/>
					<TextBox x:Name="amount6" TextAlignment="Right" BeforeTextChanging="Amount_BeforeTextChanging"/>
					<TextBox x:Name="amount7" TextAlignment="Right" BeforeTextChanging="Amount_BeforeTextChanging"/>
					<TextBox x:Name="amount8" TextAlignment="Right" BeforeTextChanging="Amount_BeforeTextChanging"/>
					<TextBox x:Name="amount9" TextAlignment="Right" BeforeTextChanging="Amount_BeforeTextChanging"/>
					<TextBox x:Name="amount10" TextAlignment="Right" BeforeTextChanging="Amount_BeforeTextChanging"/>
				</StackPanel>
			</StackPanel>


			<StackPanel Orientation="Vertical">
				<StackPanel Orientation="Horizontal" Spacing="10">
					<TextBox HorizontalAlignment="Left" Header="Mã rập :" x:Name="frameNO" Width="100" BeforeTextChanging="Amount_BeforeTextChanging"/>
					<TextBox x:Name="txtDescribe" Header="Mô tả"
                            TextWrapping="Wrap" AcceptsReturn="True" IsSpellCheckEnabled="False" Width="300" />
				</StackPanel>

				<StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Spacing="10" Margin="0,10,0,0">
					<CommandBar Background="Transparent" DefaultLabelPosition="Right">
						<AppBarButton x:Name="btnAdd" Background="#07af00" Icon="Add" Label="Thêm" Click="BtnAdd_Click" ToolTipService.ToolTip="Press F1" CornerRadius="10"
                                      IsEnabled="{x:Bind ViewModel.IsLoading, Converter={StaticResource BoolToNegationConverter}, Mode=OneWay}">
							<AppBarButton.KeyboardAccelerators>
								<KeyboardAccelerator Key="F1"/>
							</AppBarButton.KeyboardAccelerators>
						</AppBarButton>
						<AppBarButton x:Name="btnDelete" Background="#ff3800" Icon="Delete" Label="Xoá" Click="BtnDelete_Click" ToolTipService.ToolTip="Press F2" CornerRadius="10"
                                      IsEnabled="{x:Bind ViewModel.IsLoading, Converter={StaticResource BoolToNegationConverter}, Mode=OneWay}">
							<AppBarButton.KeyboardAccelerators>
								<KeyboardAccelerator Key="F2"/>
							</AppBarButton.KeyboardAccelerators>
						</AppBarButton>
						<AppBarButton x:Name="btnUpdate" Background="#b48b14" Icon="Edit" Label="Cập nhật" Click="BtnUpdate_Click" ToolTipService.ToolTip="Press F3" CornerRadius="10"
                                      IsEnabled="{x:Bind ViewModel.IsLoading, Converter={StaticResource BoolToNegationConverter}, Mode=OneWay}">
							<AppBarButton.KeyboardAccelerators>
								<KeyboardAccelerator Key="F3"/>
							</AppBarButton.KeyboardAccelerators>
						</AppBarButton>
						<AppBarButton Background="#24a6d5" Icon="Refresh" Label="làm mới" Click="BtnReset_Click" ToolTipService.ToolTip="Press F2" CornerRadius="10"
                                      IsEnabled="{x:Bind ViewModel.IsLoading, Converter={StaticResource BoolToNegationConverter}, Mode=OneWay}">
							<AppBarButton.KeyboardAccelerators>
								<KeyboardAccelerator Key="F2"/>
							</AppBarButton.KeyboardAccelerators>
						</AppBarButton>
					</CommandBar>
				</StackPanel>
			</StackPanel>
		</StackPanel>
		<StackPanel Grid.Row="1">
			<controls:DataGrid
                x:Name="PlankGrid"
                MaxHeight="600"
                Width="Auto"
                VerticalAlignment="Top"
                HorizontalAlignment="Left"
                GridLinesVisibility="All"
                CanUserReorderColumns="False"
                CanUserSortColumns="False"
                AutoGenerateColumns="False"
                IsReadOnly="True"
                ScrollViewer.VerticalScrollBarVisibility="Auto"
                ColumnHeaderStyle="{StaticResource CustomHeaderStyle}"
                HorizontalGridLinesBrush="{ThemeResource DataGridBorderColor}"
                VerticalGridLinesBrush="{ThemeResource DataGridBorderColor}"
                BorderThickness="1"
                ItemsSource="{x:Bind ViewModel.Frames, Mode=OneWay}"
                SelectionChanged="PlankGrid_SelectionChanged"
                SelectionMode="Single">

				<controls:DataGrid.Resources>
					<SolidColorBrush x:Key="DataGridColumnHeaderBackgroundColor" Color="Transparent" />
				</controls:DataGrid.Resources>

				<controls:DataGrid.Columns>
					<controls:DataGridTextColumn IsReadOnly="True" Header="Mã Rập" Binding="{Binding FrameNO}" Width="Auto">
						<controls:DataGridTextColumn.ElementStyle>
							<Style TargetType="TextBlock">
								<Setter Property="HorizontalAlignment" Value="Stretch"/>
								<Setter Property="TextAlignment" Value="Left"/>
							</Style>
						</controls:DataGridTextColumn.ElementStyle>
					</controls:DataGridTextColumn>

					<controls:DataGridTextColumn IsReadOnly="True" Header="Mô tả" Binding="{Binding Description}" Width="Auto">
						<controls:DataGridTextColumn.ElementStyle>
							<Style TargetType="TextBlock">
								<Setter Property="HorizontalAlignment" Value="Stretch"/>
								<Setter Property="TextAlignment" Value="Left"/>
							</Style>
						</controls:DataGridTextColumn.ElementStyle>
					</controls:DataGridTextColumn>
				</controls:DataGrid.Columns>
			</controls:DataGrid>

			<StackPanel>
				<ProgressRing Grid.Column="1"
                      IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                      Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"
                      Width="60" Height="60"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center" />
			</StackPanel>
		</StackPanel>

	</Grid>
</Page>