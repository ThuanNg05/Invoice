<Page
    x:Class="Invoice.Views.PlanksPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:behaviors="using:Invoice.Behaviors"
    mc:Ignorable="d">

	<Page.Resources>
		<ResourceDictionary>
			<ResourceDictionary.ThemeDictionaries>
				<ResourceDictionary x:Key="Light">
					<SolidColorBrush x:Key="DataGridBorderColor" Color="Black"/>
				</ResourceDictionary>
				<ResourceDictionary x:Key="Dark">
					<SolidColorBrush x:Key="DataGridBorderColor" Color="Gray"/>
				</ResourceDictionary>
			</ResourceDictionary.ThemeDictionaries>

			<Style x:Key="CustomHeaderStyle" TargetType="ContentControl">
				<Setter Property="FontSize" Value="15"/>
				<Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}"/>
				<Setter Property="FontWeight" Value="Bold"/>
				<Setter Property="HorizontalContentAlignment" Value="Center"/>
			</Style>
		</ResourceDictionary>
	</Page.Resources>

	<Grid x:Name="ContentArea" Padding="20">
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="Auto" />
			<ColumnDefinition Width="Auto" />
		</Grid.ColumnDefinitions>

		<StackPanel Grid.Column="0" Orientation="Vertical" Spacing="16" VerticalAlignment="Top" Margin="0,0,30,0">

			<StackPanel Orientation="Vertical" Spacing="10">
				<StackPanel Orientation="Horizontal" Spacing="10">
                    <AutoSuggestBox x:Name="txtSize1" Header="Kích thước" TextChanged="AutoSuggestBox_TextChanged" SuggestionChosen="AutoSuggestBox_SuggestionChosen" Width="Auto"/>
                    <AutoSuggestBox x:Name="txtSize2" Header=" " TextChanged="AutoSuggestBox_TextChanged" SuggestionChosen="AutoSuggestBox_SuggestionChosen" Width="Auto"/>
					<AutoSuggestBox x:Name="txtSize3" Header=" " TextChanged="AutoSuggestBox_TextChanged" SuggestionChosen="AutoSuggestBox_SuggestionChosen" Width="Auto"/>
					<AutoSuggestBox x:Name="txtSize4" Header=" " TextChanged="AutoSuggestBox_TextChanged" SuggestionChosen="AutoSuggestBox_SuggestionChosen" Width="Auto"/>
					<AutoSuggestBox x:Name="txtSize5" Header=" " TextChanged="AutoSuggestBox_TextChanged" SuggestionChosen="AutoSuggestBox_SuggestionChosen" Width="Auto"/>
					<AutoSuggestBox x:Name="txtSize6" Header=" " TextChanged="AutoSuggestBox_TextChanged" SuggestionChosen="AutoSuggestBox_SuggestionChosen" Width="Auto"/>
					<AutoSuggestBox x:Name="txtSize7" Header=" " TextChanged="AutoSuggestBox_TextChanged" SuggestionChosen="AutoSuggestBox_SuggestionChosen" Width="Auto"/>
					<AutoSuggestBox x:Name="txtSize8" Header=" " TextChanged="AutoSuggestBox_TextChanged" SuggestionChosen="AutoSuggestBox_SuggestionChosen" Width="Auto"/>
					<AutoSuggestBox x:Name="txtSize9" Header=" " TextChanged="AutoSuggestBox_TextChanged" SuggestionChosen="AutoSuggestBox_SuggestionChosen" Width="Auto"/>
                    <AutoSuggestBox x:Name="txtSize10" Header=" " TextChanged="AutoSuggestBox_TextChanged" SuggestionChosen="AutoSuggestBox_SuggestionChosen" Width="Auto"/>
				</StackPanel>

				<StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBox x:Name="txtAmount1" Header="Số lượng" TextAlignment="Right" behaviors:TextBoxInputBehavior.InputType="Numeric" Width="Auto" />
					<TextBox x:Name="txtAmount2" Header=" " TextAlignment="Right" behaviors:TextBoxInputBehavior.InputType="Numeric" Width="Auto" />
					<TextBox x:Name="txtAmount3" Header=" " TextAlignment="Right" behaviors:TextBoxInputBehavior.InputType="Numeric" Width="Auto" />
					<TextBox x:Name="txtAmount4" Header=" " TextAlignment="Right" behaviors:TextBoxInputBehavior.InputType="Numeric" Width="Auto" />
					<TextBox x:Name="txtAmount5" Header=" " TextAlignment="Right" behaviors:TextBoxInputBehavior.InputType="Numeric" Width="Auto" />
					<TextBox x:Name="txtAmount6" Header=" " TextAlignment="Right" behaviors:TextBoxInputBehavior.InputType="Numeric" Width="Auto" />
					<TextBox x:Name="txtAmount7" Header=" " TextAlignment="Right" behaviors:TextBoxInputBehavior.InputType="Numeric" Width="Auto" />
					<TextBox x:Name="txtAmount8" Header=" " TextAlignment="Right" behaviors:TextBoxInputBehavior.InputType="Numeric" Width="Auto" />
					<TextBox x:Name="txtAmount9" Header=" " TextAlignment="Right" behaviors:TextBoxInputBehavior.InputType="Numeric" Width="Auto" />
                    <TextBox x:Name="txtAmount10" Header=" " TextAlignment="Right" behaviors:TextBoxInputBehavior.InputType="Numeric" Width="Auto" />
				</StackPanel>
			</StackPanel>


            <StackPanel Orientation="Vertical">
                <Border BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" BorderThickness="1" Padding="15" CornerRadius="8" Background="{ThemeResource LayerFillColorDefaultBrush}">
                    <StackPanel Spacing="10" Width="auto" Orientation="Vertical" HorizontalAlignment="Center">
                        <StackPanel>
                            <TextBlock Text="Nhập kho nhanh" FontWeight="Bold" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBox HorizontalAlignment="Left" Header="Mã rập :" x:Name="frameNO" Width="100" behaviors:TextBoxInputBehavior.InputType="Numeric" />
                            <TextBox x:Name="txtDescribe" Header="Mô tả"
									TextWrapping="Wrap" AcceptsReturn="True" IsSpellCheckEnabled="False" Width="300" />
                            <StackPanel>
                                <TextBox x:Name="txtBigSheetQty" Header="SL tấm lớn" Width="100" behaviors:TextBoxInputBehavior.InputType="Numeric" HorizontalAlignment="Stretch"/>
                            </StackPanel>
                            <StackPanel>
                                <ComboBox x:Name="cmbMaterial" Header="Loại ván" Width="100" HorizontalAlignment="Stretch" >
                                    <ComboBoxItem Content="HP"/>
                                    <ComboBoxItem Content="MDF"/>
                                </ComboBox>
                            </StackPanel>
                        </StackPanel>
                        <Button x:Name="btnSaveStock" Content="Lưu kho" Click="BtnSaveStock_Click" HorizontalAlignment="Stretch"
								Background="#516dcf" Foreground="White" CornerRadius="5"
								IsEnabled="{x:Bind ViewModel.IsBusy, Converter={StaticResource BoolToNegationConverter}, Mode=OneWay}"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="20">
                            <CommandBar Background="Transparent" DefaultLabelPosition="Right">
                                <AppBarButton x:Name="btnAdd" Background="#07af00" Foreground="{ThemeResource SettingsForegroundBrush}"
								  Icon="Add" x:Uid="Btn_Add" Click="BtnAdd_Click" ToolTipService.ToolTip="Press F1" CornerRadius="10"
								  IsEnabled="{x:Bind ViewModel.IsBusy, Converter={StaticResource BoolToNegationConverter}, Mode=OneWay}">
                                    <AppBarButton.KeyboardAccelerators>
                                        <KeyboardAccelerator Key="F1"/>
                                    </AppBarButton.KeyboardAccelerators>
                                </AppBarButton>
                                <AppBarButton x:Name="btnDelete" Background="#ff3800" Foreground="{ThemeResource SettingsForegroundBrush}"
								  Icon="Delete" x:Uid="Btn_Delete" Click="BtnDelete_Click" ToolTipService.ToolTip="Press F2" CornerRadius="10"
								  IsEnabled="{x:Bind ViewModel.IsBusy, Converter={StaticResource BoolToNegationConverter}, Mode=OneWay}">
                                    <AppBarButton.KeyboardAccelerators>
                                        <KeyboardAccelerator Key="F2"/>
                                    </AppBarButton.KeyboardAccelerators>
                                </AppBarButton>
                                <AppBarButton x:Name="btnUpdate" Background="#b48b14" Foreground="{ThemeResource SettingsForegroundBrush}"
								  Icon="Edit" x:Uid="Btn_Update" Click="BtnUpdate_Click" ToolTipService.ToolTip="Press F3" CornerRadius="10"
								  IsEnabled="{x:Bind ViewModel.IsBusy, Converter={StaticResource BoolToNegationConverter}, Mode=OneWay}">
                                    <AppBarButton.KeyboardAccelerators>
                                        <KeyboardAccelerator Key="F3"/>
                                    </AppBarButton.KeyboardAccelerators>
                                </AppBarButton>
                                <AppBarButton Background="#24a6d5" Icon="Refresh" Foreground="{ThemeResource SettingsForegroundBrush}"
								  x:Uid="Btn_Reset" Click="BtnReset_Click" ToolTipService.ToolTip="Press F2" CornerRadius="10"
								  IsEnabled="{x:Bind ViewModel.IsBusy, Converter={StaticResource BoolToNegationConverter}, Mode=OneWay}">
                                    <AppBarButton.KeyboardAccelerators>
                                        <KeyboardAccelerator Key="F2"/>
                                    </AppBarButton.KeyboardAccelerators>
                                </AppBarButton>
                            </CommandBar>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>

		</StackPanel>
		<StackPanel Grid.Column="1">
			<controls:DataGrid
                x:Name="PlankGrid"
                MaxHeight="600"
                Width="Auto"
                VerticalAlignment="Top"
                HorizontalAlignment="Left"
                GridLinesVisibility="All"
                CanUserReorderColumns="False"
                CanUserSortColumns="False"
                AutoGenerateColumns="False"
                IsReadOnly="True"
                ScrollViewer.VerticalScrollBarVisibility="Auto"
                ColumnHeaderStyle="{StaticResource CustomHeaderStyle}"
                HorizontalGridLinesBrush="{ThemeResource DataGridBorderColor}"
                VerticalGridLinesBrush="{ThemeResource DataGridBorderColor}"
                BorderThickness="1"
                ItemsSource="{x:Bind ViewModel.Frames, Mode=OneWay}"
                SelectionChanged="PlankGrid_SelectionChanged"
                SelectionMode="Single">

				<controls:DataGrid.Resources>
					<SolidColorBrush x:Key="DataGridColumnHeaderBackgroundColor" Color="Transparent" />
				</controls:DataGrid.Resources>

				<controls:DataGrid.Columns>
					<controls:DataGridTextColumn Header="Mã Rập" Binding="{Binding FrameNO}" Width="Auto">
						<controls:DataGridTextColumn.ElementStyle>
							<Style TargetType="TextBlock">
								<Setter Property="HorizontalAlignment" Value="Stretch"/>
								<Setter Property="TextAlignment" Value="Left"/>
							</Style>
						</controls:DataGridTextColumn.ElementStyle>
					</controls:DataGridTextColumn>

					<controls:DataGridTextColumn Header="Mô tả" Binding="{Binding Description}" Width="Auto">
						<controls:DataGridTextColumn.ElementStyle>
							<Style TargetType="TextBlock">
								<Setter Property="HorizontalAlignment" Value="Stretch"/>
								<Setter Property="TextAlignment" Value="Left"/>
							</Style>
						</controls:DataGridTextColumn.ElementStyle>
					</controls:DataGridTextColumn>
				</controls:DataGrid.Columns>
			</controls:DataGrid>

			<StackPanel>
				<ProgressRing Grid.Column="1"
                      IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}"
                      Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"
                      Width="60" Height="60"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center" />
			</StackPanel>
		</StackPanel>

	</Grid>
</Page>